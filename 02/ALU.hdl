// File name: projects/02/ALU.hdl

/**
 * The ALU (Arithmetic Logic Unit).
 * Computes one of the following functions:
 * x+y, x-y, y-x, 0, 1, -1, x, y, -x, -y, !x, !y,
 * x+1, y+1, x-1, y-1, x&y, x|y
 * on the 16-bit inputs x, y,
 * according to 6 input bits denoted zx, nx, zy, ny, f, no.
 *
 * In addition, the ALU computes two 1-bit outputs:
 * if the ALU output == 0, zr is set to 1; otherwise zr is set to 0;
 * if the ALU output < 0,  ng is set to 1; otherwise ng is set to 0.
 */

CHIP ALU {
    IN  
        x[16], y[16],  // 16-bit inputs        
        zx, // zero the x input?
        nx, // negate the x input?
        zy, // zero the y input?
        ny, // negate the y input?
        f,  // compute out = x + y (if 1) or x & y (if 0)
        no; // negate the out output?

    OUT 
        out[16], // 16-bit output
        zr, // 1 if (out == 0), 0 otherwise
        ng; // 1 if (out < 0),  0 otherwise

    PARTS:
    // Handle x
    Mux16(a=x,    b=false, sel=zx, out=x1);
    Not16(in=x1,  out=notX1);
    Mux16(a=x1,   b=notX1, sel=nx, out=x2);

    // Handle y
    Mux16(a=y,    b=false, sel=zy, out=y1);
    Not16(in=y1,  out=notY1);
    Mux16(a=y1,   b=notY1, sel=ny, out=y2);

    // Compute f
    Add16(a=x2,   b=y2,   out=addOut);
    And16(a=x2,   b=y2,   out=andOut);
    Mux16(a=andOut, b=addOut, sel=f, out=fOut);

    // Handle output negation + status
    Not16(in=fOut, out=notFOut);
    Mux16(a=fOut,  b=notFOut, sel=no, out=out, out[15]=ng, out[0..7]=low8, out[8..15]=high8);

    // Compute zr
    Or8Way(in=low8,  out=orLow);
    Or8Way(in=high8, out=orHigh);
    Or(a=orLow, b=orHigh, out=notZr);
    Not(in=notZr, out=zr);
}
